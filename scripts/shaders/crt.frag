// Ретро-ЭЛТ: кривизна кинескопа + теневая RGB-маска + скан-линии + виньетка.
// Кривизна пересэмплит картинку по выгнутым координатам, из-за чего прямые края
// окон/текста зубрятся (тот самый артефакт). Поэтому выборку СГЛАЖИВАЕМ
// суперсэмплингом 2x2 по экранным производным (dFdx/dFdy).
// Скан-линии считаются в кривом пространстве (wuv) — изгибаются вместе с
// экраном. Маска привязана к физическим пикселям (gl_FragCoord), чтобы её
// частота 3px не "плавала" и не давала цветной муар.
// Статичный (time не используется) — debug-опции Hyprland не трогает.
vec3 effect(vec3 c, vec2 uv) {
    // Кривизна кинескопа.
    vec2 cc = uv - 0.5;
    vec2 wuv = uv + cc * dot(cc, cc) * 0.18;

    // Размер пикселя в координатах wuv — для суперсэмплинга (считаем ДО ветвления,
    // производные должны быть в однородном потоке управления).
    vec2 dx = dFdx(wuv);
    vec2 dy = dFdy(wuv);

    // За краем закруглённого кинескопа — чёрная рамка.
    if (any(lessThan(wuv, vec2(0.0))) || any(greaterThan(wuv, vec2(1.0)))) {
        return vec3(0.0);
    }

    // 2x2 суперсэмплинг (повёрнутая сетка) — сглаживает зубцы от кривизны.
    vec3 col = 0.25 * (
        texture(tex, wuv + 0.25 * dx + 0.25 * dy).rgb +
        texture(tex, wuv - 0.25 * dx + 0.25 * dy).rgb +
        texture(tex, wuv + 0.25 * dx - 0.25 * dy).rgb +
        texture(tex, wuv - 0.25 * dx - 0.25 * dy).rgb
    );

    // Плотность строк в пикселях через производные — не зависит от разрешения.
    float H = 1.0 / max(fwidth(uv.y), 1e-6);
    // Скан-линии считаем в КРИВОМ пространстве (wuv), а не по физическим строкам —
    // тогда они выгибаются вместе с кинескопом (период ~9px в центре).
    float scan = 0.85 + 0.15 * sin(wuv.y * H * 0.7);

    // Теневая RGB-маска с периодом 3px, по физическим пикселям.
    float ph = mod(gl_FragCoord.x, 3.0);
    vec3 mask = vec3(0.8);
    if (ph < 1.0) {
        mask.r = 1.0;
    } else if (ph < 2.0) {
        mask.g = 1.0;
    } else {
        mask.b = 1.0;
    }

    // Виньетка по краям.
    float vig = smoothstep(0.95, 0.4, length(cc));

    col *= scan * mask * mix(0.7, 1.0, vig);
    return col * 1.3; // компенсация затемнения от маски и скан-линий
}
