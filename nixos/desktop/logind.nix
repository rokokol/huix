{ ... }:

{
  # Кнопку питания обрабатывает не logind (по умолчанию — poweroff), а
  # композитор: Hyprland ловит XF86PowerOff и показывает rofi-меню питания
  # (scripts/rofi-power.sh). Без ignore система выключалась бы сразу, минуя меню.
  services.logind.settings.Login.HandlePowerKey = "ignore";

  # По умолчанию logind 30 секунд после пробуждения игнорирует события крышки
  # (ждёт, пока определятся доки/мониторы) — «открыл-закрыл» крышку выглядит
  # как отказ уходить в сон. 2s хватает на пробу hotplug-устройств, а закрытие
  # крышки срабатывает практически сразу. На ПК крышки нет — опция безвредна.
  services.logind.settings.Login.HoldoffTimeoutSec = "2s";
}
